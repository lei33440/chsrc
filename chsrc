# Generic dispatch: get_url <pm> <mirror>
get_url() {
  local pm="$1" mirror="$2"
  if declare -F "get_url_${pm}_${mirror}" >/dev/null 2>&1; then
    "get_url_${pm}_${mirror}"
  else
    return 1
  fi
}

# Mirror display name lookup
mirror_label() {
  case "$1" in
    aliyun)   t mirror_aliyun ;;
    tuna)     t mirror_tuna ;;
    ustc)     t mirror_ustc ;;
    huawei)   t mirror_huawei ;;
    tencent)  t mirror_tencent ;;
    163)      t mirror_163 ;;
    official) t mirror_official ;;
    *)        echo "$1" ;;
  esac
}

# ============================================================================
# System detection
# ============================================================================
detect_system() {
  ARCH="$(arch_normalize)"

  if [ ! -r /etc/os-release ]; then
    die "$(t detect_unknown) — /etc/os-release 不存在"
  fi

  # shellcheck disable=SC1091
  . /etc/os-release
  DISTRO_ID="${ID:-unknown}"
  DISTRO_LIKE="${ID_LIKE:-}"
  DISTRO_NAME="${NAME:-${DISTRO_ID}}"
  DISTRO_VERSION="${VERSION_ID:-}"
  DISTRO_CODENAME="${VERSION_CODENAME:-}"

  # Fallback codename from version for RHEL family
  if [ -z "${DISTRO_CODENAME}" ] && [ -n "${DISTRO_VERSION}" ]; then
    DISTRO_CODENAME="${DISTRO_VERSION%%.*}"
  fi

  case "${DISTRO_ID}" in
    debian|ubuntu|linuxmint|kali|deepin|elementary|zorin|pop|neon)
      PKG_MANAGER="apt" ;;
    centos|rhel|rocky|almalinux|opencloudos|openanolis|openEuler|anolis|fedora)
      # CentOS 7 / RHEL 7 still use yum; everything newer uses dnf
      if [ "${DISTRO_ID}" = "centos" ] && [ "${DISTRO_VERSION%%.*}" = "7" ]; then
        PKG_MANAGER="yum"
      elif [ "${DISTRO_ID}" = "rhel" ] && [ "${DISTRO_VERSION%%.*}" = "7" ]; then
        PKG_MANAGER="yum"
      else
        PKG_MANAGER="dnf"
      fi
      # Anolis / openEuler / OpenCloudOS use dnf in all versions
      ;;
    arch|manjaro|endeavouros|garuda)
      PKG_MANAGER="pacman" ;;
    opensuse*|sles|suse)
      PKG_MANAGER="zypper" ;;
    alpine|postmarketos)
      PKG_MANAGER="apk" ;;
    void)
      PKG_MANAGER="xbps" ;;
    solus)
      PKG_MANAGER="eopkg" ;;
    gentoo)
      PKG_MANAGER="portage" ;;
    *)
      # Try ID_LIKE fallback
      case "${DISTRO_LIKE}" in
        *debian*|*ubuntu*) PKG_MANAGER="apt" ;;
        *rhel*|*fedora*|*centos*) PKG_MANAGER="dnf" ;;
        *arch*) PKG_MANAGER="pacman" ;;
        *suse*) PKG_MANAGER="zypper" ;;
        *) die "$(t detect_unknown): ${DISTRO_ID}" ;;
      esac
      ;;
  esac
}

print_status() {
  detect_system
  printf "%s%s%s\n" "${C_BOLD}" "$(t detect_distro)" "${C_RESET}"
  printf "  %-12s %s\n" "ID"        "${DISTRO_ID}"
  printf "  %-12s %s\n" "Name"      "${DISTRO_NAME}"
  printf "  %-12s %s\n" "Version"   "${DISTRO_VERSION}"
  printf "  %-12s %s\n" "Codename"  "${DISTRO_CODENAME}"
  printf "  %-12s %s\n" "$(t detect_pm)"   "${PKG_MANAGER}"
  printf "  %-12s %s\n" "$(t detect_arch)" "${ARCH}"
}

# ============================================================================
# Backup / restore
# ============================================================================
backup_file() {
  # backup_file <path> — keeps a timestamped copy, records in manifest
  local target="$1"
  [ -e "${target}" ] || return 0
  local ts bak
  ts="$(date +%Y%m%d%H%M%S)"
  bak="${target}.bak.${ts}"
  run cp -p "${target}" "${bak}"
  if [ "${DRY_RUN}" -eq 0 ]; then
    mkdir -p "${CHSRC_STATE_DIR}"
    printf "%s\t%s\n" "${bak}" "${target}" >> "${CHSRC_MANIFEST}"
  fi
}

restore_latest() {
  [ -f "${CHSRC_MANIFEST}" ] || die "$(t err_no_backup)"
  # Read manifest in reverse to find most recent entry for each target
  local target bak
  declare -A seen
  while IFS=$'\t' read -r bak target; do
    [ -n "${target}" ] || continue
    if [ -z "${seen[${target}]:-}" ] && [ -f "${bak}" ]; then
      run cp -p "${bak}" "${target}"
      log_ok "$(t restored): ${target} ← ${bak}"
      seen["${target}"]=1
    fi
  done < <(tac "${CHSRC_MANIFEST}")
}

# ============================================================================
# Source writers — one per package manager
# Each writes the standard sources file(s) for the detected distro + mirror.
# They all call backup_file() first, then write the new content via run().
# ============================================================================

# --- apt ---
write_apt() {
  local mirror="$1" base
  base="$(get_url apt "${mirror}")" || die "$(t err_mirror_unknown): ${mirror}"
  local code="${DISTRO_CODENAME:-}"
  [ -n "${code}" ] || die "无法取得发行版代号 (VERSION_CODENAME 为空)"

  if [ "${mirror}" = "official" ] || [ -z "${base}" ]; then
    log_info "已选择 official 源，不做修改"
    return 0
  fi

  local file="/etc/apt/sources.list"
  backup_file "${file}"

  local content
  content="$(cat <<EOF
# Generated by chsrc on $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Mirror: $(mirror_label "${mirror}") (${base})
deb ${base}/${DISTRO_ID} ${code} main contrib non-free non-free-firmware
deb ${base}/${DISTRO_ID} ${code}-updates main contrib non-free non-free-firmware
deb ${base}/${DISTRO_ID} ${code}-backports main contrib non-free non-free-firmware
deb ${base}/${DISTRO_ID}-security ${code}-security main contrib non-free non-free-firmware
EOF
)"
  # For Ubuntu, the layout is slightly different
  if [ "${DISTRO_ID}" = "ubuntu" ]; then
    content="$(cat <<EOF
# Generated by chsrc on $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Mirror: $(mirror_label "${mirror}") (${base})
deb ${base}/ubuntu ${code} main restricted universe multiverse
deb ${base}/ubuntu ${code}-updates main restricted universe multiverse
deb ${base}/ubuntu ${code}-backports main restricted universe multiverse
deb ${base}/ubuntu ${code}-security main restricted universe multiverse
EOF
)"
  fi

  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将写入 %s：\n" "${C_YELLOW}" "${C_RESET}" "${file}"
    printf "%s\n" "${content}"
  else
    printf "%s\n" "${content}" > "${file}"
  fi

  log_step "$(t step_refresh)"
  run apt-get update -o Acquire::Retries=2 -o Acquire::http::Timeout=10
}

# --- yum (CentOS 7 / RHEL 7) ---
write_yum() {
  local mirror="$1" base
  base="$(get_url yum "${mirror}")" || die "$(t err_mirror_unknown): ${mirror}"
  if [ "${mirror}" = "official" ] || [ -z "${base}" ]; then
    log_info "已选择 official 源，不做修改"
    return 0
  fi
  local ver="${DISTRO_VERSION%%.*}"
  local repo_dir="/etc/yum.repos.d"
  backup_file "${repo_dir}/CentOS-Base.repo"

  local file="${repo_dir}/CentOS-Base.repo"
  local content
  content="$(cat <<EOF
# Generated by chsrc on $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Mirror: $(mirror_label "${mirror}") (${base})
[base]
name=CentOS-\$releasever - Base - $(mirror_label "${mirror}")
baseurl=${base}/centos/\$releasever/os/\$basearch/
gpgcheck=1
gpgkey=${base}/centos/RPM-GPG-KEY-CentOS-${ver}

[updates]
name=CentOS-\$releasever - Updates - $(mirror_label "${mirror}")
baseurl=${base}/centos/\$releasever/updates/\$basearch/
gpgcheck=1
gpgkey=${base}/centos/RPM-GPG-KEY-CentOS-${ver}

[extras]
name=CentOS-\$releasever - Extras - $(mirror_label "${mirror}")
baseurl=${base}/centos/\$releasever/extras/\$basearch/
gpgcheck=1
gpgkey=${base}/centos/RPM-GPG-KEY-CentOS-${ver}
EOF
)"
  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将写入 %s\n" "${C_YELLOW}" "${C_RESET}" "${file}"
    printf "%s\n" "${content}"
  else
    printf "%s\n" "${content}" > "${file}"
  fi
  log_step "$(t step_refresh)"
  run yum clean all
  run yum makecache
}

# --- dnf (Fedora / RHEL 8+ / Rocky / Alma / openEuler etc) ---
write_dnf() {
  local mirror="$1" base
  base="$(get_url yum "${mirror}")" || die "$(t err_mirror_unknown): ${mirror}"
  if [ "${mirror}" = "official" ] || [ -z "${base}" ]; then
    log_info "已选择 official 源，不做修改"
    return 0
  fi

  local repo_dir="/etc/yum.repos.d"
  local repo_file=""
  case "${DISTRO_ID}" in
    fedora)         repo_file="${repo_dir}/fedora.repo" ;;
    rocky|almalinux) repo_file="${repo_dir}/Rocky-Base.repo" ;;
    openEuler)      repo_file="${repo_dir}/openEuler.repo" ;;
    anolis|openanolis) repo_file="${repo_dir}/AnolisOS.repo" ;;
    opencloudos)    repo_file="${repo_dir}/OpenCloudOS.repo" ;;
    *)              repo_file="${repo_dir}/${DISTRO_ID}.repo" ;;
  esac
  backup_file "${repo_file}"

  # Fedora-specific layout
  if [ "${DISTRO_ID}" = "fedora" ]; then
    local ver="${DISTRO_VERSION}"
    local content
    content="$(cat <<EOF
# Generated by chsrc on $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Mirror: $(mirror_label "${mirror}") (${base})
[fedora]
name=Fedora ${ver} - $(mirror_label "${mirror}")
baseurl=${base}/fedora/releases/${ver}/Everything/\$basearch/os/
gpgcheck=1
gpgkey=${base}/fedora/releases/${ver}/Everything/\$basearch/os/RPM-GPG-KEY-fedora-${ver}-${ARCH}

[updates]
name=Fedora ${ver} - Updates - $(mirror_label "${mirror}")
baseurl=${base}/fedora/updates/${ver}/Everything/\$basearch/
gpgcheck=1
gpgkey=${base}/fedora/releases/${ver}/Everything/\$basearch/os/RPM-GPG-KEY-fedora-${ver}-${ARCH}
EOF
)"
    if [ "${DRY_RUN}" -eq 1 ]; then
      printf "%s[dry-run]%s 将写入 %s\n" "${C_YELLOW}" "${C_RESET}" "${repo_file}"
      printf "%s\n" "${content}"
    else
      printf "%s\n" "${content}" > "${repo_file}"
    fi
    log_step "$(t step_refresh)"
    run dnf clean all
    run dnf makecache
    return 0
  fi

  # Generic RHEL-family layout
  local ver="${DISTRO_VERSION%%.*}"
  local content
  content="$(cat <<EOF
# Generated by chsrc on $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Mirror: $(mirror_label "${mirror}") (${base})
[baseos]
name=${DISTRO_NAME} BaseOS - $(mirror_label "${mirror}")
baseurl=${base}/${DISTRO_ID}/os/\$basearch/
gpgcheck=1
enabled=1

[appstream]
name=${DISTRO_NAME} AppStream - $(mirror_label "${mirror}")
baseurl=${base}/${DISTRO_ID}/appstream/\$basearch/
gpgcheck=1
enabled=1

[extras]
name=${DISTRO_NAME} Extras - $(mirror_label "${mirror}")
baseurl=${base}/${DISTRO_ID}/extras/\$basearch/
gpgcheck=1
enabled=1
EOF
)"
  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将写入 %s\n" "${C_YELLOW}" "${C_RESET}" "${repo_file}"
    printf "%s\n" "${content}"
  else
    printf "%s\n" "${content}" > "${repo_file}"
  fi
  log_step "$(t step_refresh)"
  run dnf clean all
  run dnf makecache
}

# --- pacman (Arch) ---
write_pacman() {
  local mirror="$1" base
  base="$(get_url pacman "${mirror}")" || die "$(t err_mirror_unknown): ${mirror}"
  local file="/etc/pacman.d/mirrorlist"
  backup_file "${file}"

  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将置顶 %s：%s\n" "${C_YELLOW}" "${C_RESET}" "${file}" "${base}/\$repo/os/\$arch"
  else
    {
      printf "## Generated by chsrc on %s\n" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      printf "## Mirror: %s\n" "$(mirror_label "${mirror}")"
      printf "Server = %s/\$repo/os/\$arch\n" "${base}"
      printf "\n"
      [ -f "${file}" ] && tail -n +1 "${file}.bak."* 2>/dev/null | grep -v '^##' | grep -v '^Server' | grep -v '^$' || true
    } > "${file}"
  fi
  log_step "$(t step_refresh)"
  run pacman -Sy
}

# --- zypper (openSUSE) ---
write_zypper() {
  local mirror="$1" base
  base="$(get_url zypper "${mirror}")" || die "$(t err_mirror_unknown): ${mirror}"
  if [ "${mirror}" = "official" ] || [ -z "${base}" ]; then
    log_info "已选择 official 源，不做修改"
    return 0
  fi

  local ver="${DISTRO_VERSION}"
  [ -n "${ver}" ] || ver="${DISTRO_CODENAME:-tumbleweed}"
  # zypper mr + ar (managed by zypper)
  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将添加 repo %s\n" "${C_YELLOW}" "${C_RESET}" "${base}/distribution/leap/${ver}/repo/oss"
  else
    run zypper mr -da || true
    run zypper ar -fcg "${base}/distribution/leap/${ver}/repo/oss" "chsrc-oss" || true
    run zypper ar -fcg "${base}/distribution/leap/${ver}/repo/non-oss" "chsrc-non-oss" || true
    run zypper ar -fcg "${base}/update/leap/${ver}/oss" "chsrc-update-oss" || true
    run zypper ar -fcg "${base}/update/leap/${ver}/non-oss" "chsrc-update-non-oss" || true
  fi
  log_step "$(t step_refresh)"
  run zypper ref
}

# --- apk (Alpine) ---
write_apk() {
  local mirror="$1" base
  base="$(get_url apk "${mirror}")" || die "$(t err_mirror_unknown): ${mirror}"
  local file="/etc/apk/repositories"
  backup_file "${file}"

  local ver="${DISTRO_VERSION%%.*}"
  local content
  content="$(cat <<EOF
# Generated by chsrc on $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Mirror: $(mirror_label "${mirror}") (${base})
${base}/v${ver}/main
${base}/v${ver}/community
EOF
)"
  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将写入 %s\n" "${C_YELLOW}" "${C_RESET}" "${file}"
    printf "%s\n" "${content}"
  else
    printf "%s\n" "${content}" > "${file}"
  fi
  log_step "$(t step_refresh)"
  run apk update
}

# --- xbps (Void) ---
write_xbps() {
  local mirror="$1" base
  base="https://mirrors.aliyun.com/voidlinux"  # xbps mirror support varies
  local file="/etc/xbps.d/00-chsrc.conf"
  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将写入 %s\n" "${C_YELLOW}" "${C_RESET}" "${file}"
  else
    run install -d /etc/xbps.d
    run sh -c "echo 'repository=${base}/current/${ARCH}/nonfree' > ${file}"
    run sh -c "echo 'repository=${base}/current/${ARCH}/multilib' >> ${file}"
    run sh -c "echo 'repository=${base}/current/${ARCH}/multilib/nonfree' >> ${file}"
  fi
  log_step "$(t step_refresh)"
  run xbps-install -S
}

# --- eopkg (Solus) ---
write_eopkg() {
  local mirror="$1" base
  base="$(get_url yum "${mirror}")"  # Solus uses Aliyun's mirror at mirrors.aliyun.com/solinux
  if [ "${mirror}" = "aliyun" ]; then
    base="https://mirrors.aliyun.com/solinux"
  fi
  local file="/etc/eopkg/sources.conf"
  backup_file "${file}"

  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将替换 %s\n" "${C_YELLOW}" "${C_RESET}" "${file}"
  else
    run sed -i "s|^https://mirror\.solus\.com|${base}|g" "${file}"
  fi
  log_step "$(t step_refresh)"
  run eopkg update-repo
}

# --- portage (Gentoo) ---
write_portage() {
  local mirror="$1" base
  case "${mirror}" in
    aliyun)   base="https://mirrors.aliyun.com/gentoo" ;;
    tuna)     base="https://mirrors.tuna.tsinghua.edu.cn/gentoo" ;;
    ustc)     base="https://mirrors.ustc.edu.cn/gentoo" ;;
    huawei)   base="https://mirrors.huaweicloud.com/gentoo" ;;
    tencent)  base="https://mirrors.cloud.tencent.com/gentoo" ;;
    163)      base="https://mirrors.163.com/gentoo" ;;
    official) base="https://distfiles.gentoo.org" ;;
  esac

  local file="/etc/portage/repos.conf/gentoo.conf"
  backup_file "${file}"

  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将替换 sync-uri 为 %s\n" "${C_YELLOW}" "${C_RESET}" "${base}/snapshots"
  else
    run sed -i "s|^sync-uri = .*|sync-uri = ${base}/snapshots|" "${file}"
  fi
  log_step "$(t step_refresh)"
  run emerge --sync
}

# Dispatch
write_source() {
  local mirror="$1"
  detect_system
  case "${PKG_MANAGER}" in
    apt)     write_apt "${mirror}" ;;
    yum)     write_yum "${mirror}" ;;
    dnf)     write_dnf "${mirror}" ;;
    pacman)  write_pacman "${mirror}" ;;
    zypper)  write_zypper "${mirror}" ;;
    apk)     write_apk "${mirror}" ;;
    xbps)    write_xbps "${mirror}" ;;
    eopkg)   write_eopkg "${mirror}" ;;
    portage) write_portage "${mirror}" ;;
    *)       die "$(t err_unsupported): ${PKG_MANAGER}" ;;
  esac
}

# ============================================================================
# Interactive selector — generic numbered menu
# ============================================================================
# select_from_list <prompt> <default_idx> <label1> <value1> <label2> <value2> ...
# Prints the selected VALUE to stdout.
# All menu display goes to stderr (>/dev/tty if available) so the caller can
# safely use $(select_from_list ...) to capture only the chosen value.
# In non-TTY / --yes mode, returns the default's value without prompting.
select_from_list() {
  local prompt="$1"
  local default_idx="$2"
  shift 2
  if [ $(( $# % 2 )) -ne 0 ]; then
    die "select_from_list: 参数必须成对 (label value)"
  fi
  local -a labels=()
  local -a values=()
  while [ $# -gt 0 ]; do
    labels+=("$1"); values+=("$2"); shift 2
  done

  if [ ! -t 0 ] || [ "${ASSUME_YES}" -eq 1 ]; then
    if [ "${default_idx}" -ge 1 ] && [ "${default_idx}" -le "${#values[@]}" ]; then
      echo "${values[$((default_idx - 1))]}"
      return 0
    fi
  fi

  # Pick the best fd for menu display: /dev/tty if open, else stderr.
  local out=2
  [ -w /dev/tty ] 2>/dev/null && out=/dev/tty

  {
    printf "%s%s%s\n" "${C_BOLD}" "${prompt}" "${C_RESET}"
    local i=1
    for label in "${labels[@]}"; do
      if [ "$i" -eq "${default_idx}" ]; then
        printf "  %s%d)%s %s %s[默认]%s\n" "${C_GREEN}" "${i}" "${C_RESET}" "${label}" "${C_YELLOW}" "${C_RESET}"
      else
        printf "  %d) %s\n" "${i}" "${label}"
      fi
      i=$((i + 1))
    done
    printf "请选择 [${default_idx}]: "
  } >"$out"

  # Read from /dev/tty if available so the read doesn't consume stdin we're
  # already using elsewhere (e.g. piped input). Falls back to stdin.
  local choice
  if [ -r /dev/tty ] 2>/dev/null; then
    read -r choice < /dev/tty
  else
    read -r choice
  fi
  choice="${choice:-${default_idx}}"
  if ! [[ "${choice}" =~ ^[0-9]+$ ]] || [ "${choice}" -lt 1 ] || [ "${choice}" -gt "${#values[@]}" ]; then
    printf "  %s无效选择: %s%s\n" "${C_RED}" "${choice}" "${C_RESET}" >"$out"
    return 1
  fi
  echo "${values[$((choice - 1))]}"
  return 0
}

# Pick a mirror. Honors TARGET_MIRROR if set, else shows a numbered menu.
pick_mirror() {
  if [ -n "${TARGET_MIRROR}" ]; then
    echo "${TARGET_MIRROR}"
    return 0
  fi
  select_from_list "$(t select_mirror)" 1 \
    "$(t mirror_aliyun)"   aliyun \
    "$(t mirror_tuna)"     tuna \
    "$(t mirror_ustc)"     ustc \
    "$(t mirror_huawei)"   huawei \
    "$(t mirror_tencent)"  tencent \
    "$(t mirror_163)"      163 \
    "$(t mirror_official)" official
}

# ============================================================================
# Speed test
# ============================================================================
speedtest() {
  local pm
  pm="$(detect_pkg_manager_silent)"
  log_info "$(t speedtest_running)"

  local mirrors=(aliyun tuna ustc huawei tencent 163)
  local result_file
  result_file="$(mktemp)"
  trap 'rm -f "${result_file}"' RETURN

  for m in "${mirrors[@]}"; do
    local url
    if ! url="$(get_url "${pm}" "${m}" 2>/dev/null)"; then
      continue
    fi
    if [ -z "${url}" ]; then
      continue
    fi
    # Probe a small known-stable file
    local probe="${url}/"
    case "${pm}" in
      apt)     probe="${url}/${DISTRO_ID}/dists/${DISTRO_CODENAME}/Release" ;;
      yum|dnf) probe="${url}/centos/" ;;
      pacman)  probe="${url}/os/" ;;
      zypper)  probe="${url}/" ;;
      apk)     probe="${url}/v${DISTRO_VERSION%%.*}/main/" ;;
    esac
    (
      t=$(curl -o /dev/null -s -m 5 -w "%{time_total}" "${probe}" 2>/dev/null || echo "999")
      printf "%s\t%s\t%s\n" "${t}" "${m}" "${url}" >> "${result_file}"
    ) &
  done
  wait

  printf "\n%s\n" "$(t speedtest_result):"
  printf "%-8s  %-20s  %s\n" "Latency" "Mirror" "URL"
  sort -n "${result_file}" | while IFS=$'\t' read -r t m url; do
    printf "%-8s  %-20s  %s\n" "${t}s" "$(mirror_label "${m}")" "${url}"
  done
}

detect_pkg_manager_silent() {
  if [ -z "${PKG_MANAGER}" ]; then
    detect_system
  fi
  echo "${PKG_MANAGER}"
}

# ============================================================================
# Docker module
# ============================================================================
docker_installed() {
  command -v docker >/dev/null 2>&1
}

docker_status() {
  if ! docker_installed; then
    log_warn "Docker 未安装"
    return 1
  fi
  if docker version >/dev/null 2>&1; then
    local v
    v="$(docker version --format '{{.Server.Version}}' 2>/dev/null || echo unknown)"
    log_ok "$(t docker_installed): ${v}"
    docker info 2>/dev/null | sed -n '/Registry Mirrors:/,/Live Restore Enabled:/p' | head -n -1 | sed 's/^/  /' || true
  else
    log_warn "Docker 已安装但守护进程未运行"
  fi
}

docker_install() {
  local method="${TARGET_MIRROR:-${MIRROR_ALIYUN}}"
  if docker_installed; then
    log_ok "$(t docker_installed)"
    return 0
  fi
  detect_system
  log_info "$(t docker_installing) (${method})"

  case "${PKG_MANAGER}" in
    apt)
      if [ "${method}" = "official" ]; then
        run curl -fsSL https://download.docker.com/linux/${DISTRO_ID}/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
        echo "deb [arch=${ARCH} signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/${DISTRO_ID} ${DISTRO_CODENAME} stable" > /etc/apt/sources.list.d/docker.list
      else
        local base
        base="$(get_url apt "${method}")"
        run curl -fsSL "${base}/docker-ce/linux/${DISTRO_ID}/gpg" | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
        echo "deb [arch=${ARCH} signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] ${base}/docker-ce/linux/${DISTRO_ID} ${DISTRO_CODENAME} stable" > /etc/apt/sources.list.d/docker.list
      fi
      run apt-get update
      run apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
      ;;
    yum|dnf)
      if [ "${PKG_MANAGER}" = "yum" ]; then
        run yum install -y yum-utils
        run yum-config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo
      else
        run dnf -y install dnf-plugins-core
        if [ "${method}" = "official" ]; then
          run dnf config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo
        else
          local base
          base="$(get_url dnf "${method}")"
          run dnf config-manager --add-repo "${base}/docker-ce/linux/centos/docker-ce.repo"
        fi
      fi
      run "${PKG_MANAGER}" install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
      ;;
    pacman)
      run pacman -Sy --noconfirm docker docker-compose
      ;;
    *)
      die "Docker 自动安装不支持该发行版（${DISTRO_ID}），请参考 https://docs.docker.com/engine/install/ 手动安装"
      ;;
  esac

  run systemctl enable --now docker
  if docker_installed; then
    log_ok "$(t docker_installed)"
  else
    die "Docker 安装失败"
  fi
}

docker_mirror() {
  docker_installed || die "$(t err_docker_not_installed)"

  local cfg="/etc/docker/daemon.json"
  backup_file "${cfg}"

  local mirrors='["https://docker.mirrors.aliyun.com","https://mirror.ccs.tencentyun.com","https://mirrors.huaweicloud.com/repository/docker"]'
  local content
  content="$(printf '{\n  "registry-mirrors": %s\n}\n' "${mirrors}")"

  if [ "${DRY_RUN}" -eq 1 ]; then
    printf "%s[dry-run]%s 将写入 %s：\n" "${C_YELLOW}" "${C_RESET}" "${cfg}"
    printf "%s\n" "${content}"
  else
    run install -d /etc/docker
    printf "%s" "${content}" > "${cfg}"
  fi
  run systemctl restart docker
  log_ok "$(t docker_mirror_set)"
  docker_status
}

docker_self_update() {
  log_info "$(t updating_self)"
  if [ "${DRY_RUN}" -eq 1 ]; then
    log_warn "dry-run 模式不执行实际更新"
    return 0
  fi
  local tmp
  tmp="$(mktemp)"
  if curl -fsSL -o "${tmp}" "${CHSRC_RAW_URL}"; then
    if grep -q "CHSRC_VERSION=\"${CHSRC_VERSION}\"" "${tmp}"; then
      log_ok "$(t updated): ${CHSRC_VERSION}"
    else
      run install -m 755 "${tmp}" "/usr/local/bin/${CHSRC_NAME}"
      log_ok "已更新到新版本"
    fi
  else
    log_err "下载失败，请检查网络"
    return 1
  fi
  rm -f "${tmp}"
}

# ============================================================================
# Argument parsing
# ============================================================================
usage() {
  cat <<EOF
${C_BOLD}$(t help_title)${C_RESET}  v${CHSRC_VERSION}

${C_BOLD}默认行为${C_RESET}
  直接执行 chsrc 进入交互式主菜单（自动识别系统、编号选择功能）

${C_BOLD}$(t help_usage)${C_RESET}
  chsrc                       # 进入主菜单（默认）
  chsrc <subcommand> [args]   # 直接执行子命令（适合脚本）

${C_BOLD}$(t help_subcmds)${C_RESET}
  status                      显示当前系统识别结果
  list                        列出支持的发行版与镜像源
  set [mirror]                换源（默认交互；可指定 aliyun|tuna|ustc|huawei|tencent|163|official）
  restore                     从备份还原
  backup                      手动备份当前源
  speedtest                   测速各镜像源
  update                      自更新到最新版本

  docker install              安装 Docker
  docker mirror               配置 Docker registry-mirrors
  docker status               查看 Docker 与镜像状态

  version                     显示版本
  help                        显示本帮助

${C_BOLD}$(t help_opts)${C_RESET}
  --yes, -y                   $(t opt_yes)
  --dry-run                   $(t opt_dry)
  --lang <zh|en>              $(t opt_lang)
  --verbose                   $(t opt_verbose)
  -h, --help                  显示帮助

${C_BOLD}示例${C_RESET}
  sudo chsrc                       # 进入菜单
  sudo chsrc set tuna              # 直接换 tuna 源
  sudo chsrc set aliyun --yes      # 非交互换 aliyun 源
  sudo chsrc speedtest             # 测速
  sudo chsrc docker install        # 装 Docker
  sudo chsrc docker mirror         # 配置 Docker 镜像加速
  curl -fsSL https://raw.githubusercontent.com/${CHSRC_REPO}/main/chsrc | sudo bash -s -- status

项目主页：https://github.com/${CHSRC_REPO}
EOF
}

parse_args() {
  # First pass: find any mirror positional that follows `set`, since flags may
  # appear in any order (e.g. `chsrc set --yes tuna`).
  local -a _args=()
  while [ $# -gt 0 ]; do
    _args+=("$1")
    shift
  done
  set -- "${_args[@]}"
  unset _args

  # Find a non-flag arg that comes after `set` and isn't part of another subcommand
  local i=1
  while [ $i -le $# ]; do
    local cur="${!i}"
    if [ "$cur" = "set" ]; then
      local j=$((i + 1))
      while [ $j -le $# ]; do
        local nxt="${!j}"
        if [ "$nxt" = "--" ]; then break; fi
        if [[ "$nxt" =~ ^- ]]; then
          j=$((j + 1))
          continue
        fi
        TARGET_MIRROR="$nxt"
        break
      done
    fi
    i=$((i + 1))
  done

  # Second pass: dispatch
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes|-y)         ASSUME_YES=1 ;;
      --dry-run)        DRY_RUN=1 ;;
      --verbose)        VERBOSE=1 ;;
      --lang)           [ $# -ge 2 ] || die "--lang 需要参数"; LANG_CODE="$2"; shift ;;
      --lang=*)         LANG_CODE="${1#--lang=}" ;;
      -h|--help|help)   usage; exit 0 ;;
      version)          echo "${CHSRC_NAME} v${CHSRC_VERSION}"; exit 0 ;;
      status)           CMD="status" ;;
      list)             CMD="list" ;;
      set)              CMD="set" ;;
      restore)          CMD="restore" ;;
      backup)           CMD="backup" ;;
      speedtest)        CMD="speedtest" ;;
      update)           CMD="update" ;;
      docker)
                        [ $# -ge 2 ] || die "docker 需要子命令 (install|mirror|status)"
                        case "$2" in
                          install) CMD="docker_install" ;;
                          mirror)  CMD="docker_mirror" ;;
                          status)  CMD="docker_status" ;;
                          *)       die "未知 docker 子命令: $2" ;;
                        esac
                        shift 2
                        ;;
      --)               shift; break ;;
      -*)               die "未知选项: $1" ;;
      *)                : ;;  # already captured by first pass
    esac
    shift
  done
  CMD="${CMD:-menu}"
}

