# ============================================================================
# Main menu — the default UX when chsrc is run with no subcommand
# ============================================================================
print_banner() {
  printf "\n%s%s%s\n" "${C_BOLD}${C_BLUE}" "=== chsrc v${CHSRC_VERSION} ===" "${C_RESET}"
  if [ -n "${DISTRO_ID:-}" ]; then
    # Build a compact one-liner: Name Version (codename) / pkg_mgr / arch
    local left="${DISTRO_NAME:-${DISTRO_ID}}"
    [ -n "${DISTRO_VERSION:-}" ] && left="${left} ${DISTRO_VERSION}"
    [ -n "${DISTRO_CODENAME:-}" ] && left="${left} (${DISTRO_CODENAME})"
    printf "  %s%-32s%s %s/%s/%s\n" \
      "${C_BOLD}${C_GREEN}" "${left}" "${C_RESET}" \
      "${PKG_MANAGER}" "${ARCH}" "${DISTRO_ID}"
  fi
}

cmd_menu() {
  detect_system
  # We need an actual terminal for interactive input. Check /dev/tty (the
  # controlling terminal) rather than stdin, so the menu still works when
  # the script itself is piped in via `curl | sudo bash`.
  if [ ! -r /dev/tty ] && [ "${ASSUME_YES}" -eq 0 ]; then
    log_warn "无可用终端，请直接用子命令（如 chsrc set tuna --yes）"
    usage
    return 1
  fi
  # Refuse menu if system is unrecognized (detect_system already died in that case)
  while true; do
    print_banner
    local choice=""
    # select_from_list returns 0 + echoes value on success, 1 on invalid input
    # (it doesn't die in that case). Capture both stdout and the exit code.
    local rc=0
    choice="$(select_from_list "$(t menu_title)" 1 \
      "$(t menu_set)"             set \
      "$(t menu_docker_install)"  docker_install \
      "$(t menu_docker_mirror)"   docker_mirror \
      "$(t menu_speedtest)"       speedtest \
      "$(t menu_backup)"          backup \
      "$(t menu_restore)"         restore \
      "$(t menu_status)"          status \
      "$(t menu_quit)"            quit
    )" || rc=$?
    if [ "${rc}" -ne 0 ] || [ -z "${choice}" ]; then
      # invalid input → redraw menu without "press enter" pause
      continue
    fi
    printf "\n"
    case "${choice}" in
      set)
        local_mirror="$(pick_mirror || true)"
        if [ -z "${local_mirror}" ]; then
          log_warn "已取消"
        else
          detect_system
          log_step "$(t step_backup)"
          log_step "$(t step_write)"
          write_source "${local_mirror}"
          log_ok "$(t step_done)"
        fi ;;
      docker_install) docker_install ;;
      docker_mirror)  docker_mirror  ;;
      speedtest)      speedtest      ;;
      backup)         cmd_backup     ;;
      restore)        restore_latest ;;
      status)         print_status   ;;
      quit)           printf "%s%s%s\n" "${C_GREEN}" "$(t goodbye)" "${C_RESET}"; return 0 ;;
      *)              log_warn "未知选项: ${choice}" ;;
    esac
    if [ -r /dev/tty ] 2>/dev/null; then
      printf "\n" >/dev/tty
      printf "%s%s%s" "${C_YELLOW}" "$(t press_enter)" "${C_RESET}" >/dev/tty
      read -r _ < /dev/tty
    fi
  done
}

# ============================================================================
# Main
# ============================================================================
main() {
  parse_args "$@"
  # Privilege check (status / list / help / version / speedtest / menu are safe)
  case "${CMD}" in
    status|list|help|version|speedtest|menu) : ;;
    *) ensure_root "$@" ;;
  esac

  case "${CMD}" in
    help)            usage ;;
    menu)            cmd_menu ;;
    status)          print_status ;;
    list)            cmd_list ;;
    set)             local_mirror="$(pick_mirror)"
                     detect_system
                     log_step "$(t step_backup)"
                     log_step "$(t step_write)"
                     write_source "${local_mirror}"
                     log_ok "$(t step_done)" ;;
    restore)         restore_latest ;;
    backup)          cmd_backup ;;
    speedtest)       speedtest ;;
    update)          docker_self_update ;;
    docker_install)  docker_install ;;
    docker_mirror)   docker_mirror ;;
    docker_status)   docker_status ;;
    *)               die "未知子命令: ${CMD}" ;;
  esac
}

main "$@"
