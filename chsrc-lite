#!/usr/bin/env bash
# chsrc-lite — Standalone Linux system source switcher (no menu, no Docker)
# https://github.com/lei33440/chsrc
# License: MIT
#
# Usage: chsrc-lite [global opts] <mirror>
#   mirror = aliyun|tuna|ustc|huawei|tencent|163|official|pku|zju|nju|sjtu|hust|...
#
# One-shot: curl -fsSL .../chsrc-lite | sudo bash -s -- tuna

set -o errexit
set -o nounset
set -o pipefail

