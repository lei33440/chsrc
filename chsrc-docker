#!/usr/bin/env bash
# chsrc-docker — Standalone Docker installer + registry-mirrors configurator
# https://github.com/lei33440/chsrc
# License: MIT
#
# Usage: chsrc-docker [global opts] <subcommand>
#   install [mirror]        Install Docker (mirror: aliyun|tuna|ustc|...|official)
#   mirror                  Configure /etc/docker/daemon.json registry-mirrors
#   status                  Show Docker version + configured mirrors
#   help                    Show help
#
# One-shot: curl -fsSL .../chsrc-docker | sudo bash -s -- install aliyun

set -o errexit
set -o nounset
set -o pipefail

readonly CHSRC_VERSION="0.1.0"
readonly CHSRC_NAME="chsrc-docker"
readonly CHSRC_REPO="lei33440/chsrc"
readonly CHSRC_RAW_URL="https://raw.githubusercontent.com/${CHSRC_REPO}/main/chsrc-docker"

LANG_CODE="zh"
ASSUME_YES=0
DRY_RUN=0
VERBOSE=0
TARGET_MIRROR=""

DISTRO_ID=""
DISTRO_LIKE=""
DISTRO_NAME=""
DISTRO_VERSION=""
DISTRO_CODENAME=""
PKG_MANAGER=""
ARCH=""

